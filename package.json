{
  "name": "simple-kafka-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node out/server/index.js",
    "build": "npm run build:ui && npm run build:server",
    "dev": "nodemon -e ts,tsx --exec \"npm run build:server && npm run build:ui && npm start\"",
    "lint": "next lint",
    "build:ui": "next build",   
    "build:server": "tsc --build tsconfig.server.json"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "bootstrap": "^5.3.2",
    "express": "^4.18.2",
    "next": "14.1.0",
    "nodemon": "^3.0.3",
    "react": "^18",
    "react-dom": "^18",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "typescript": "^5"
  }
}
